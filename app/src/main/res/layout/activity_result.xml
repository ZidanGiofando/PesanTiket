<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Sukses -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pemesanan Berhasil!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Terima kasih telah memesan tiket di PesanTiket"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Card: Ringkasan Pemesanan -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ringkasan Pemesanan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E50914"
                    android:layout_marginBottom="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.8"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Aksi -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tindakan Lanjutan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E50914"
                    android:layout_marginBottom="12dp" />

                <!-- Share -->
                <Button
                    android:id="@+id/btnShare"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Bagikan Pesanan"
                    android:backgroundTint="#1976D2"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <!-- Email -->
                <Button
                    android:id="@+id/btnEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Kirim Email Konfirmasi"
                    android:backgroundTint="#FF6F00"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <!-- Call -->
                <Button
                    android:id="@+id/btnCall"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Hubungi Bioskop"
                    android:backgroundTint="#388E3C"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <!-- Web -->
                <Button
                    android:id="@+id/btnWeb"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Buka Website Bioskop"
                    android:backgroundTint="#7B1FA2"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Kembali -->
        <Button
            android:id="@+id/btnKembali"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Kembali ke Form"
            android:backgroundTint="#616161"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
