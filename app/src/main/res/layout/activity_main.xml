<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== HEADER ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PESANTIKET"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#E50914"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pemesanan Tiket Bioskop Online"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- ===== IMAGE VIEW (poster/banner) ===== -->
        <ImageView
            android:id="@+id/ivPoster"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:src="@drawable/ic_movie_banner"
            android:scaleType="fitXY"
            android:layout_marginBottom="12dp"
            android:contentDescription="Movie Banner" />

        <!-- ===== FRAGMENT: Info Bioskop ===== -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- ===== CARD: Data Penonton ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data Penonton"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E50914"
                    android:layout_marginBottom="12dp" />

                <!-- Nama -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nama Lengkap *"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />
                <EditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan nama lengkap"
                    android:inputType="textPersonName"
                    android:background="@drawable/edittext_background"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp" />

                <!-- Email -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alamat Email *"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="contoh@email.com"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/edittext_background"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp" />

                <!-- Phone -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nomor HP *"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="08xxxxxxxxxx (angka saja)"
                    android:inputType="phone"
                    android:background="@drawable/edittext_background"
                    android:padding="10dp"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== CARD: Detail Pemesanan ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Detail Pemesanan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E50914"
                    android:layout_marginBottom="12dp" />

                <!-- Spinner: Pilih Film -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pilih Film *"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />
                <Spinner
                    android:id="@+id/spinnerFilm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_background"
                    android:layout_marginBottom="12dp" />

                <!-- DatePicker: Tanggal -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Tayang *"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/btnTanggal"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Pilih Tanggal"
                        android:textSize="12sp"
                        android:backgroundTint="#E50914"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/tvTanggal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Belum dipilih"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:paddingStart="12dp" />
                </LinearLayout>

                <!-- Jumlah Tiket -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jumlah Tiket * (1 - 10)"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />
                <EditText
                    android:id="@+id/etJumlahTiket"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan jumlah tiket"
                    android:inputType="number"
                    android:background="@drawable/edittext_background"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp" />

                <!-- RadioGroup: Jenis Kursi -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jenis Kursi *"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/rgKursi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Regular\nRp50.000"
                        android:textSize="12sp"
                        android:buttonTint="#E50914"
                        android:tag="Regular" />

                    <RadioButton
                        android:id="@+id/rbVIP"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VIP\nRp100.000"
                        android:textSize="12sp"
                        android:buttonTint="#E50914"
                        android:tag="VIP" />

                    <RadioButton
                        android:id="@+id/rbVVIP"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VVIP\nRp150.000"
                        android:textSize="12sp"
                        android:buttonTint="#E50914"
                        android:tag="VVIP" />
                </RadioGroup>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== CARD: Extras / Tambahan ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tambahan (Opsional)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E50914"
                    android:layout_marginBottom="12dp" />

                <CheckBox
                    android:id="@+id/cbPopcorn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Popcorn — Rp 25.000"
                    android:textSize="14sp"
                    android:buttonTint="#E50914"
                    android:layout_marginBottom="4dp" />

                <CheckBox
                    android:id="@+id/cbMinuman"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Minuman — Rp 15.000"
                    android:textSize="14sp"
                    android:buttonTint="#E50914"
                    android:layout_marginBottom="4dp" />

                <CheckBox
                    android:id="@+id/cbCombo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Combo Meal — Rp 35.000"
                    android:textSize="14sp"
                    android:buttonTint="#E50914" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== TOMBOL PESAN ===== -->
        <Button
            android:id="@+id/btnPesan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="PESAN SEKARANG"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#E50914"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
